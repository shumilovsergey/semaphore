# {{ ansible_managed }}
# Создаётся один раз. HTTPS-блок (listen 443) добавляет certbot.
# Чтобы переприменить изменения — удали этот файл и запусти роль заново.

# HTTP server (will later be upgraded to HTTPS by Certbot)
server {
    listen 80;
    server_name {{ item.domain }};

    location / {
{% if item.vpn_only | default(false) %}
        # allow only specific IP (VPN)
        allow {{ vpn_allow_ip }};
        deny all;
{% endif %}

        proxy_pass http://127.0.0.1:{{ item.port }};

        # preserve original host & client info
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # avoid redirect loops when SSL is added later
        proxy_set_header X-Forwarded-Proto http;
        proxy_set_header X-Forwarded-Port 80;

        # websocket/long-poll stability (harmless if unused)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
